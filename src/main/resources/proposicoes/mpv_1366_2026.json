ntainersOmissis":[{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Omissis","prefix":"","key":"{http://www.lexml.gov.br/1.0}Omissis","string":"{http://www.lexml.gov.br/1.0}Omissis"},"value":{"TYPE_NAME":"br_gov_lexml__1.Omissis","id":"art1_cpt_alt1_art7_cpt_inc1_omi1"}},{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Alinea","prefix":"","key":"{http://www.lexml.gov.br/1.0}Alinea","string":"{http://www.lexml.gov.br/1.0}Alinea"},"value":{"TYPE_NAME":"br_gov_lexml__1.DispositivoType","href":"art7_cpt_inc1_ali10","id":"art1_cpt_alt1_art7_cpt_inc1_ali10","fechaAspas":"s","notaAlteracao":"NR","rotulo":"j)","p":[{"TYPE_NAME":"br_gov_lexml__1.GenInline","content":["\n    beneficiários da linha de financiamento de que trata o ",{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"span","prefix":"","key":"{http://www.lexml.gov.br/1.0}span","string":"{http://www.lexml.gov.br/1.0}span"},"value":{"TYPE_NAME":"br_gov_lexml__1.GenInline","href":"urn:lex:br:federal:lei:2024-08-02;14947!art8-1","content":["art. 8º-A da Lei nº 14.947, de 2 de agosto de 2024"]}},".\n\n  "]}]}}]}}]}}]}}]}}}]}},{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Artigo","prefix":"","key":"{http://www.lexml.gov.br/1.0}Artigo","string":"{http://www.lexml.gov.br/1.0}Artigo"},"value":{"TYPE_NAME":"br_gov_lexml__1.DispositivoType","id":"art2","rotulo":"Art. 2º","lXcontainersOmissis":[{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Caput","prefix":"","key":"{http://www.lexml.gov.br/1.0}Caput","string":"{http://www.lexml.gov.br/1.0}Caput"},"value":{"TYPE_NAME":"br_gov_lexml__1.DispositivoType","id":"art2_cpt","p":[{"TYPE_NAME":"br_gov_lexml__1.GenInline","content":["\n    A ",{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"span","prefix":"","key":"{http://www.lexml.gov.br/1.0}span","string":"{http://www.lexml.gov.br/1.0}span"},"value":{"TYPE_NAME":"br_gov_lexml__1.GenInline","href":"urn:lex:br:federal:lei:2020-05-18;13999","content":["Lei nº 13.999, de 18 de maio de 2020"]}},", passa a vigorar com as seguintes alterações: \n\n  "]}],"alteracao":{"TYPE_NAME":"br_gov_lexml__1.Alteracao","base":"urn:lex:br:federal:lei:2020-05-18;13999","id":"art2_cpt_alt1","content":[{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Artigo","prefix":"","key":"{http://www.lexml.gov.br/1.0}Artigo","string":"{http://www.lexml.gov.br/1.0}Artigo"},"value":{"TYPE_NAME":"br_gov_lexml__1.DispositivoType","href":"art6-10","id":"art2_cpt_alt1_art6-10","abreAspas":"s","rotulo":"Art. 6º-J.","lXcontainersOmissis":[{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Caput","prefix":"","key":"{http://www.lexml.gov.br/1.0}Caput","string":"{http://www.lexml.gov.br/1.0}Caput"},"value":{"TYPE_NAME":"br_gov_lexml__1.DispositivoType","href":"art6-10_cpt","id":"art2_cpt_alt1_art6-10_cpt","p":[{"TYPE_NAME":"br_gov_lexml__1.GenInline","content":["\n    Fica autorizada a utilização de recursos não comprometidos do FGO para a cobertura das operações nas linhas de financiamento disponibilizadas no âmbito do Fundo Nacional de Investimento em Infraestrutura Social – FIIS, de que trata o ",{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"span","prefix":"","key":"{http://www.lexml.gov.br/1.0}span","string":"{http://www.lexml.gov.br/1.0}span"},"value":{"TYPE_NAME":"br_gov_lexml__1.GenInline","href":"urn:lex:br:federal:lei:2024-08-02;14947!art8-1","content":["art. 8º-A da Lei nº 14.947, de 2 de agosto de 2024"]}},", conforme estabelecido no estatuto do FGO. \n\n  "]}]}},{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Paragrafo","prefix":"","key":"{http://www.lexml.gov.br/1.0}Paragrafo","string":"{http://www.lexml.gov.br/1.0}Paragrafo"},"value":{"TYPE_NAME":"br_gov_lexml__1.DispositivoType","href":"art6-10_par1","id":"art2_cpt_alt1_art6-10_par1","rotulo":"§ 1º","p":[{"TYPE_NAME":"br_gov_lexml__1.GenInline","content":["\n    Ato conjunto do Ministro de Estado do Desenvolvimento, Indústria, Comércio e Serviços e do Ministro de Estado da Fazenda poderá dispor sobre a alocação dos recursos, os critérios de elegibilidade dos beneficiários e as operações de crédito que poderão ser passíveis de garantia com recursos do FGO. \n\n  "]}]}},{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Paragrafo","prefix":"","key":"{http://www.lexml.gov.br/1.0}Paragrafo","string":"{http://www.lexml.gov.br/1.0}Paragrafo"},"value":{"TYPE_NAME":"br_gov_lexml__1.DispositivoType","href":"art6-10_par2","id":"art2_cpt_alt1_art6-10_par2","rotulo":"§ 2º","p":[{"TYPE_NAME":"br_gov_lexml__1.GenInline","content":["\n    As instituições financeiras autorizadas a contratar as operações de financiamento de que trata este artigo poderão requerer a garantia do FGO, conforme estabelecido no estatuto do Fundo. \n\n  "]}]}},{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Paragrafo","prefix":"","key":"{http://www.lexml.gov.br/1.0}Paragrafo","string":"{http://www.lexml.gov.br/1.0}Paragrafo"},"value":{"TYPE_NAME":"br_gov_lexml__1.DispositivoType","href":"art6-10_par3","id":"art2_cpt_alt1_art6-10_par3","fechaAspas":"s","notaAlteracao":"NR","rotulo":"§ 3º","p":[{"TYPE_NAME":"br_gov_lexml__1.GenInline","content":["\n    As instituições financeiras a que se refere o § 2º poderão contar com garantia a ser prestada pelo FGO de até 100% (cem por cento) do valor de cada operação garantida, limitada a 50% (cinquenta por cento) da carteira garantida de cada instituição financeira, conforme estabelecido no estatuto do Fundo.\n\n  "]}]}}]}}]}}}]}},{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Artigo","prefix":"","key":"{http://www.lexml.gov.br/1.0}Artigo","string":"{http://www.lexml.gov.br/1.0}Artigo"},"value":{"TYPE_NAME":"br_gov_lexml__1.DispositivoType","id":"art3","rotulo":"Art. 3º","lXcontainersOmissis":[{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Caput","prefix":"","key":"{http://www.lexml.gov.br/1.0}Caput","string":"{http://www.lexml.gov.br/1.0}Caput"},"value":{"TYPE_NAME":"br_gov_lexml__1.DispositivoType","id":"art3_cpt","p":[{"TYPE_NAME":"br_gov_lexml__1.GenInline","content":["\n    A ",{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"span","prefix":"","key":"{http://www.lexml.gov.br/1.0}span","string":"{http://www.lexml.gov.br/1.0}span"},"value":{"TYPE_NAME":"br_gov_lexml__1.GenInline","href":"urn:lex:br:federal:lei:2024-08-02;14947","content":["Lei nº 14.947, de 2 de agosto de 2024"]}},", passa a vigorar com as seguintes alterações: \n\n  "]}],"alteracao":{"TYPE_NAME":"br_gov_lexml__1.Alteracao","base":"urn:lex:br:federal:lei:2024-08-02;14947","id":"art3_cpt_alt1","content":[{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Artigo","prefix":"","key":"{http://www.lexml.gov.br/1.0}Artigo","string":"{http://www.lexml.gov.br/1.0}Artigo"},"value":{"TYPE_NAME":"br_gov_lexml__1.DispositivoType","href":"art4","id":"art3_cpt_alt1_art4","abreAspas":"s","rotulo":"Art. 4º","lXcontainersOmissis":[{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Caput","prefix":"","key":"{http://www.lexml.gov.br/1.0}Caput","string":"{http://www.lexml.gov.br/1.0}Caput"},"value":{"TYPE_NAME":"br_gov_lexml__1.DispositivoType","href":"art4_cpt","id":"art3_cpt_alt1_art4_cpt","textoOmitido":"s"}},{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Omissis","prefix":"","key":"{http://www.lexml.gov.br/1.0}Omissis","string":"{http://www.lexml.gov.br/1.0}Omissis"},"value":{"TYPE_NAME":"br_gov_lexml__1.Omissis","id":"art3_cpt_alt1_art4_omi1"}},{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Paragrafo","prefix":"","key":"{http://www.lexml.gov.br/1.0}Paragrafo","string":"{http://www.lexml.gov.br/1.0}Paragrafo"},"value":{"TYPE_NAME":"br_gov_lexml__1.DispositivoType","href":"art4_par4","id":"art3_cpt_alt1_art4_par4","textoOmitido":"s","rotulo":"§ 4º","lXcontainersOmissis":[{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Omissis","prefix":"","key":"{http://www.lexml.gov.br/1.0}Omissis","string":"{http://www.lexml.gov.br/1.0}Omissis"},"value":{"TYPE_NAME":"br_gov_lexml__1.Omissis","id":"art3_cpt_alt1_art4_par4_omi1"}},{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Inciso","prefix":"","key":"{http://www.lexml.gov.br/1.0}Inciso","string":"{http://www.lexml.gov.br/1.0}Inciso"},"value":{"TYPE_NAME":"br_gov_lexml__1.DispositivoType","href":"art4_par4_inc4","id":"art3_cpt_alt1_art4_par4_inc4","rotulo":"IV –","p":[{"TYPE_NAME":"br_gov_lexml__1.GenInline","content":["\n    outras atividades de relevante interesse social, inclusive a renovação de frota e infraestrutura ligada ao aumento de produtividade e à descarbonização dos serviços de transporte urbano individual de passageiros ou de cargas, segundo regulamentação de seu Comitê Gestor. \n\n  "]}]}}]}},{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Omissis","prefix":"","key":"{http://www.lexml.gov.br/1.0}Omissis","string":"{http://www.lexml.gov.br/1.0}Omissis"},"value":{"TYPE_NAME":"br_gov_lexml__1.Omissis","id":"art3_cpt_alt1_art4_omi2","fechaAspas":"s","notaAlteracao":"NR"}}]}},{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Artigo","prefix":"","key":"{http://www.lexml.gov.br/1.0}Artigo","string":"{http://www.lexml.gov.br/1.0}Artigo"},"value":{"TYPE_NAME":"br_gov_lexml__1.DispositivoType","href":"art6","id":"art3_cpt_alt1_art6","abreAspas":"s","rotulo":"Art. 6º","lXcontainersOmissis":[{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Caput","prefix":"","key":"{http://www.lexml.gov.br/1.0}Caput","string":"{http://www.lexml.gov.br/1.0}Caput"},"value":{"TYPE_NAME":"br_gov_lexml__1.DispositivoType","href":"art6_cpt","id":"art3_cpt_alt1_art6_cpt","p":[{"TYPE_NAME":"br_gov_lexml__1.GenInline","content":["\n    O FIIS terá como agentes financeiros o Banco Nacional de Desenvolvimento Econômico e Social – BNDES, o Banco do Brasil S.A. e a Caixa Econômica Federal. \n\n  "]}]}},{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Paragrafo","prefix":"","key":"{http://www.lexml.gov.br/1.0}Paragrafo","string":"{http://www.lexml.gov.br/1.0}Paragrafo"},"value":{"TYPE_NAME":"br_gov_lexml__1.DispositivoType","href":"art6_par1u","id":"art3_cpt_alt1_art6_par1u","fechaAspas":"s","notaAlteracao":"NR","rotulo":"Parágrafo único.","p":[{"TYPE_NAME":"br_gov_lexml__1.GenInline","content":["\n    As instituições financeiras de que trata o ",{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"i","prefix":"","key":"{http://www.lexml.gov.br/1.0}i","string":"{http://www.lexml.gov.br/1.0}i"},"value":{"TYPE_NAME":"br_gov_lexml__1.GenInline","content":["caput"]}}," poderão habilitar outros agentes financeiros ou ",{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"i","prefix":"","key":"{http://www.lexml.gov.br/1.0}i","string":"{http://www.lexml.gov.br/1.0}i"},"value":{"TYPE_NAME":"br_gov_lexml__1.GenInline","content":["financial technologies"]}}," – ",{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"i","prefix":"","key":"{http://www.lexml.gov.br/1.0}i","string":"{http://www.lexml.gov.br/1.0}i"},"value":{"TYPE_NAME":"br_gov_lexml__1.GenInline","content":["fintechs"]}},", públicos ou privados, para atuar nas operações de financiamento com recursos do FIIS, desde que os riscos da atuação sejam suportados por esses agentes financeiros.\n\n  "]}]}}]}},{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Artigo","prefix":"","key":"{http://www.lexml.gov.br/1.0}Artigo","string":"{http://www.lexml.gov.br/1.0}Artigo"},"value":{"TYPE_NAME":"br_gov_lexml__1.DispositivoType","href":"art8","id":"art3_cpt_alt1_art8","abreAspas":"s","rotulo":"Art. 8º","lXcontainersOmissis":[{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Caput","prefix":"","key":"{http://www.lexml.gov.br/1.0}Caput","string":"{http://www.lexml.gov.br/1.0}Caput"},"value":{"TYPE_NAME":"br_gov_lexml__1.DispositivoType","href":"art8_cpt","id":"art3_cpt_alt1_art8_cpt","p":[{"TYPE_NAME":"br_gov_lexml__1.GenInline","content":["\n    Constitui obrigação do BNDES, do Banco do Brasil S.A. e da Caixa Econômica Federal apresentar, anualmente, ao Comitê Gestor do FIIS, relatório circunstanciado sobre as operações de financiamento com recursos do FIIS. \n\n  "]}]}},{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Paragrafo","prefix":"","key":"{http://www.lexml.gov.br/1.0}Paragrafo","string":"{http://www.lexml.gov.br/1.0}Paragrafo"},"value":{"TYPE_NAME":"br_gov_lexml__1.DispositivoType","href":"art8_par1u","id":"art3_cpt_alt1_art8_par1u","fechaAspas":"s","notaAlteracao":"NR","rotulo":"Parágrafo único.","p":[{"TYPE_NAME":"br_gov_lexml__1.GenInline","content":["\n    Os agentes financeiros de que trata o ",{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"i","prefix":"","key":"{http://www.lexml.gov.br/1.0}i","string":"{http://www.lexml.gov.br/1.0}i"},"value":{"TYPE_NAME":"br_gov_lexml__1.GenInline","content":["caput"]}}," manterão atualizadas, em sítio eletrônico de fácil acesso ao cidadão, informações sobre as operações de financiamento com recursos do FIIS, observados os princípios da transparência e da publicidade, nos termos do disposto na ",{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"span","prefix":"","key":"{http://www.lexml.gov.br/1.0}span","string":"{http://www.lexml.gov.br/1.0}span"},"value":{"TYPE_NAME":"br_gov_lexml__1.GenInline","href":"urn:lex:br:federal:lei:2011-11-18;12527","content":["Lei nº 12.527, de 18 de novembro de 2011"]}},".\n\n  "]}]}}]}},{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Artigo","prefix":"","key":"{http://www.lexml.gov.br/1.0}Artigo","string":"{http://www.lexml.gov.br/1.0}Artigo"},"value":{"TYPE_NAME":"br_gov_lexml__1.DispositivoType","href":"art8-1","id":"art3_cpt_alt1_art8-1","abreAspas":"s","rotulo":"Art. 8º-A.","lXcontainersOmissis":[{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Caput","prefix":"","key":"{http://www.lexml.gov.br/1.0}Caput","string":"{http://www.lexml.gov.br/1.0}Caput"},"value":{"TYPE_NAME":"br_gov_lexml__1.DispositivoType","href":"art8-1_cpt","id":"art3_cpt_alt1_art8-1_cpt","p":[{"TYPE_NAME":"br_gov_lexml__1.GenInline","content":["\n    A aplicação dos recursos do FIIS na atividade de que trata o art. 4º, § 4º, inciso IV, será realizada por meio da disponibilização de linhas de financiamento reembolsável para investimentos em infraestruturas, equipamentos e renovação da frota de veículos de serviços de transporte urbano individual de passageiros ou de cargas que contribuam para a mitigação dos custos ambientais, sociais e econômicos dos deslocamentos de pessoas e cargas nas cidades, conforme critérios estabelecidos em ato do Comitê de que trata o § 11. \n\n  "]}]}},{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Paragrafo","prefix":"","key":"{http://www.lexml.gov.br/1.0}Paragrafo","string":"{http://www.lexml.gov.br/1.0}Paragrafo"},"value":{"TYPE_NAME":"br_gov_lexml__1.DispositivoType","href":"art8-1_par1","id":"art3_cpt_alt1_art8-1_par1","rotulo":"§ 1º","p":[{"TYPE_NAME":"br_gov_lexml__1.GenInline","content":["\n    O Ministério do Desenvolvimento, Indústria, Comércio e Serviços habilitará as empresas fabricantes e publicará listas identificadas dos fabricantes, das marcas e dos modelos dos veículos elegíveis às linhas de financiamento de que trata o ",{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"i","prefix":"","key":"{http://www.lexml.gov.br/1.0}i","string":"{http://www.lexml.gov.br/1.0}i"},"value":{"TYPE_NAME":"br_gov_lexml__1.GenInline","content":["caput"]}},", quando couber. \n\n  "]}]}},{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Paragrafo","prefix":"","key":"{http://www.lexml.gov.br/1.0}Paragrafo","string":"{http://www.lexml.gov.br/1.0}Paragrafo"},"value":{"TYPE_NAME":"br_gov_lexml__1.DispositivoType","href":"art8-1_par2","id":"art3_cpt_alt1_art8-1_par2","rotulo":"§ 2º","p":[{"TYPE_NAME":"br_gov_lexml__1.GenInline","content":["\n    Na hipótese de financiamento de renovação de frota em serviços de transporte remunerado privado individual de passageiros ou de cargas, será exigida a habilitação das plataformas digitais intermediadoras dos serviços, que será realizada pelo Ministério do Desenvolvimento, Indústria, Comércio e Serviços. \n\n  "]}]}},{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Paragrafo","prefix":"","key":"{http://www.lexml.gov.br/1.0}Paragrafo","string":"{http://www.lexml.gov.br/1.0}Paragrafo"},"value":{"TYPE_NAME":"br_gov_lexml__1.DispositivoType","href":"art8-1_par3","id":"art3_cpt_alt1_art8-1_par3","rotulo":"§ 3º","p":[{"TYPE_NAME":"br_gov_lexml__1.GenInline","content":["\n    Ato do Comitê de que trata o § 11 poderá estabelecer contrapartidas obrigatórias: \n\n  "]}],"lXcontainersOmissis":[{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Inciso","prefix":"","key":"{http://www.lexml.gov.br/1.0}Inciso","string":"{http://www.lexml.gov.br/1.0}Inciso"},"value":{"TYPE_NAME":"br_gov_lexml__1.DispositivoType","href":"art8-1_par3_inc1","id":"art3_cpt_alt1_art8-1_par3_inc1","rotulo":"I –","p":[{"TYPE_NAME":"br_gov_lexml__1.GenInline","content":["\n    aos fabricantes dos equipamentos e veículos, incluída a definição de concessão de descontos mínimos aplicáveis aos produtos; e \n\n  "]}]}},{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Inciso","prefix":"","key":"{http://www.lexml.gov.br/1.0}Inciso","string":"{http://www.lexml.gov.br/1.0}Inciso"},"value":{"TYPE_NAME":"br_gov_lexml__1.DispositivoType","href":"art8-1_par3_inc2","id":"art3_cpt_alt1_art8-1_par3_inc2","rotulo":"II –","p":[{"TYPE_NAME":"br_gov_lexml__1.GenInline","content":["\n    aos beneficiários das linhas de financiamento de infraestrutura ligada a descarbonização dos serviços de transporte urbano individual de passageiros ou de cargas. \n\n  "]}]}}]}},{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Paragrafo","prefix":"","key":"{http://www.lexml.gov.br/1.0}Paragrafo","string":"{http://www.lexml.gov.br/1.0}Paragrafo"},"value":{"TYPE_NAME":"br_gov_lexml__1.DispositivoType","href":"art8-1_par4","id":"art3_cpt_alt1_art8-1_par4","rotulo":"§ 4º","p":[{"TYPE_NAME":"br_gov_lexml__1.GenInline","content":["\n    Para as linhas de financiamento de que trata este artigo, o FIIS poderá ter como agentes financeiros o BNDES, o Banco do Brasil S.A. e a Caixa Econômica Federal, dispensada a licitação. \n\n  "]}]}},{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Paragrafo","prefix":"","key":"{http://www.lexml.gov.br/1.0}Paragrafo","string":"{http://www.lexml.gov.br/1.0}Paragrafo"},"value":{"TYPE_NAME":"br_gov_lexml__1.DispositivoType","href":"art8-1_par5","id":"art3_cpt_alt1_art8-1_par5","rotulo":"§ 5º","p":[{"TYPE_NAME":"br_gov_lexml__1.GenInline","content":["\n    O BNDES, o Banco do Brasil S.A. e a Caixa Econômica Federal, na condição de agentes financeiros do FIIS: \n\n  "]}],"lXcontainersOmissis":[{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Inciso","prefix":"","key":"{http://www.lexml.gov.br/1.0}Inciso","string":"{http://www.lexml.gov.br/1.0}Inciso"},"value":{"TYPE_NAME":"br_gov_lexml__1.DispositivoType","href":"art8-1_par5_inc1","id":"art3_cpt_alt1_art8-1_par5_inc1","rotulo":"I –","p":[{"TYPE_NAME":"br_gov_lexml__1.GenInline","content":["\n    poderão habilitar outros agentes financeiros ou ",{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"i","prefix":"","key":"{http://www.lexml.gov.br/1.0}i","string":"{http://www.lexml.gov.br/1.0}i"},"value":{"TYPE_NAME":"br_gov_lexml__1.GenInline","content":["fintechs"]}},", públicos ou privados, desde que os riscos da atuação sejam suportados por esses agentes financeiros; \n\n  "]}]}},{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Inciso","prefix":"","key":"{http://www.lexml.gov.br/1.0}Inciso","string":"{http://www.lexml.gov.br/1.0}Inciso"},"value":{"TYPE_NAME":"br_gov_lexml__1.DispositivoType","href":"art8-1_par5_inc2","id":"art3_cpt_alt1_art8-1_par5_inc2","rotulo":"II –","p":[{"TYPE_NAME":"br_gov_lexml__1.GenInline","content":["\n    poderão contratar, de forma direta e sem licitação, empresa pública federal para operacionalizar o processo de identificação dos mutuários beneficiários das linhas de financiamento de que trata este artigo; e \n\n  "]}]}},{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Inciso","prefix":"","key":"{http://www.lexml.gov.br/1.0}Inciso","string":"{http://www.lexml.gov.br/1.0}Inciso"},"value":{"TYPE_NAME":"br_gov_lexml__1.DispositivoType","href":"art8-1_par5_inc3","id":"art3_cpt_alt1_art8-1_par5_inc3","rotulo":"III –","p":[{"TYPE_NAME":"br_gov_lexml__1.GenInline","content":["\n    deverão apresentar, anualmente, ao Comitê Gestor do FIIS, relatório circunstanciado sobre as operações de financiamento com recursos do FIIS. \n\n  "]}]}}]}},{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Paragrafo","prefix":"","key":"{http://www.lexml.gov.br/1.0}Paragrafo","string":"{http://www.lexml.gov.br/1.0}Paragrafo"},"value":{"TYPE_NAME":"br_gov_lexml__1.DispositivoType","href":"art8-1_par6","id":"art3_cpt_alt1_art8-1_par6","rotulo":"§ 6º","p":[{"TYPE_NAME":"br_gov_lexml__1.GenInline","content":["\n    A concordância do mutuário, realizada em sítio eletrônico, para fins de requerimento de acesso às linhas de financiamento, implicará consentimento e autorização para o compartilhamento de informações de que trata o § 7º. \n\n  "]}]}},{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Paragrafo","prefix":"","key":"{http://www.lexml.gov.br/1.0}Paragrafo","string":"{http://www.lexml.gov.br/1.0}Paragrafo"},"value":{"TYPE_NAME":"br_gov_lexml__1.DispositivoType","href":"art8-1_par7","id":"art3_cpt_alt1_art8-1_par7","rotulo":"§ 7º","p":[{"TYPE_NAME":"br_gov_lexml__1.GenInline","content":["\n    Observado o disposto no § 6º, as informações necessárias para análise da elegibilidade dos beneficiários poderão ser compartilhadas com o Ministério do Desenvolvimento, Indústria, Comércio e Serviços e com o agente financeiro: \n\n  "]}],"lXcontainersOmissis":[{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Inciso","prefix":"","key":"{http://www.lexml.gov.br/1.0}Inciso","string":"{http://www.lexml.gov.br/1.0}Inciso"},"value":{"TYPE_NAME":"br_gov_lexml__1.DispositivoType","href":"art8-1_par7_inc1","id":"art3_cpt_alt1_art8-1_par7_inc1","rotulo":"I –","p":[{"TYPE_NAME":"br_gov_lexml__1.GenInline","content":["\n    pela plataforma digital intermediadora, no caso de beneficiários de financiamento de renovação de frota de veículos de serviços de transporte remunerado privado individual de passageiros ou de cargas; \n\n  "]}]}},{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Inciso","prefix":"","key":"{http://www.lexml.gov.br/1.0}Inciso","string":"{http://www.lexml.gov.br/1.0}Inciso"},"value":{"TYPE_NAME":"br_gov_lexml__1.DispositivoType","href":"art8-1_par7_inc2","id":"art3_cpt_alt1_art8-1_par7_inc2","rotulo":"II –","p":[{"TYPE_NAME":"br_gov_lexml__1.GenInline","content":["\n    pela Secretaria Especial da Receita Federal do Brasil do Ministério da Fazenda ou por outros órgãos ou entidades federais detentores de bases de dados, no caso de beneficiários de financiamento de renovação de frota de veículos de serviços de transporte público individual de passageiros; ou \n\n  "]}]}},{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Inciso","prefix":"","key":"{http://www.lexml.gov.br/1.0}Inciso","string":"{http://www.lexml.gov.br/1.0}Inciso"},"value":{"TYPE_NAME":"br_gov_lexml__1.DispositivoType","href":"art8-1_par7_inc3","id":"art3_cpt_alt1_art8-1_par7_inc3","rotulo":"III –","p":[{"TYPE_NAME":"br_gov_lexml__1.GenInline","content":["\n    pelo Ministério do Trabalho e Emprego, no caso de beneficiários de financiamento de renovação de frota de veículos de serviços de transporte remunerado privado de cargas ou passageiros, que possuam vínculo formal de emprego, nos termos do disposto na ",{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"span","prefix":"","key":"{http://www.lexml.gov.br/1.0}span","string":"{http://www.lexml.gov.br/1.0}span"},"value":{"TYPE_NAME":"br_gov_lexml__1.GenInline","href":"urn:lex:br:federal:decreto.lei:1943-05-01;5452","content":["Consolidação das Leis do Trabalho"]}}," – ",{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"span","prefix":"","key":"{http://www.lexml.gov.br/1.0}span","string":"{http://www.lexml.gov.br/1.0}span"},"value":{"TYPE_NAME":"br_gov_lexml__1.GenInline","href":"urn:lex:br:federal:decreto.lei:1943-05-01;5452","content":["CLT"]}},", aprovada pelo ",{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"span","prefix":"","key":"{http://www.lexml.gov.br/1.0}span","string":"{http://www.lexml.gov.br/1.0}span"},"value":{"TYPE_NAME":"br_gov_lexml__1.GenInline","href":"urn:lex:br:federal:decreto.lei:1943-05-01;5452","content":["Decreto-Lei nº 5.452, de 1º de maio de 1943"]}},". \n\n  "]}]}}]}},{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Paragrafo","prefix":"","key":"{http://www.lexml.gov.br/1.0}Paragrafo","string":"{http://www.lexml.gov.br/1.0}Paragrafo"},"value":{"TYPE_NAME":"br_gov_lexml__1.DispositivoType","href":"art8-1_par8","id":"art3_cpt_alt1_art8-1_par8","rotulo":"§ 8º","p":[{"TYPE_NAME":"br_gov_lexml__1.GenInline","content":["\n    O consentimento e a autorização de que trata o § 6º: \n\n  "]}],"lXcontainersOmissis":[{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Inciso","prefix":"","key":"{http://www.lexml.gov.br/1.0}Inciso","string":"{http://www.lexml.gov.br/1.0}Inciso"},"value":{"TYPE_NAME":"br_gov_lexml__1.DispositivoType","href":"art8-1_par8_inc1","id":"art3_cpt_alt1_art8-1_par8_inc1","rotulo":"I –","p":[{"TYPE_NAME":"br_gov_lexml__1.GenInline","content":["\n    deverão constar dos contratos de financiamento e do sítio eletrônico a que se refere o § 7º; e \n\n  "]}]}},{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Inciso","prefix":"","key":"{http://www.lexml.gov.br/1.0}Inciso","string":"{http://www.lexml.gov.br/1.0}Inciso"},"value":{"TYPE_NAME":"br_gov_lexml__1.DispositivoType","href":"art8-1_par8_inc2","id":"art3_cpt_alt1_art8-1_par8_inc2","rotulo":"II –","p":[{"TYPE_NAME":"br_gov_lexml__1.GenInline","content":["\n    abrangem o repasse das informações aos agentes financeiros habilitados, ao Ministério do Desenvolvimento, Indústria, Comércio e Serviços e, conforme o caso, ao FGI ou ao FGO, na hipótese de a operação contar com garantia dos respectivos Fundos. \n\n  "]}]}}]}},{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Paragrafo","prefix":"","key":"{http://www.lexml.gov.br/1.0}Paragrafo","string":"{http://www.lexml.gov.br/1.0}Paragrafo"},"value":{"TYPE_NAME":"br_gov_lexml__1.DispositivoType","href":"art8-1_par9","id":"art3_cpt_alt1_art8-1_par9","rotulo":"§ 9º","p":[{"TYPE_NAME":"br_gov_lexml__1.GenInline","content":["\n    As informações a que se refere o § 7º serão utilizadas exclusivamente para fins da análise quanto à elegibilidade do solicitante à linha de financiamento, com base nos critérios a que se refere o ",{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"i","prefix":"","key":"{http://www.lexml.gov.br/1.0}i","string":"{http://www.lexml.gov.br/1.0}i"},"value":{"TYPE_NAME":"br_gov_lexml__1.GenInline","content":["caput"]}},", e da eventual concessão da linha de financiamento, vedada qualquer outra utilização. \n\n  "]}]}},{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Paragrafo","prefix":"","key":"{http://www.lexml.gov.br/1.0}Paragrafo","string":"{http://www.lexml.gov.br/1.0}Paragrafo"},"value":{"TYPE_NAME":"br_gov_lexml__1.DispositivoType","href":"art8-1_par10","id":"art3_cpt_alt1_art8-1_par10","rotulo":"§ 10.","p":[{"TYPE_NAME":"br_gov_lexml__1.GenInline","content":["\n    Para fins da execução da linha de financiamento de que trata o inciso II do § 7º, ficam a Secretaria Especial da Receita Federal do Brasil ou outros órgãos ou entidades federais detentores de bases de dados autorizados a encaminhar ao Ministério do Desenvolvimento, Indústria, Comércio e Serviços a identificação dos beneficiários. \n\n  "]}]}},{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Paragrafo","prefix":"","key":"{http://www.lexml.gov.br/1.0}Paragrafo","string":"{http://www.lexml.gov.br/1.0}Paragrafo"},"value":{"TYPE_NAME":"br_gov_lexml__1.DispositivoType","href":"art8-1_par11","id":"art3_cpt_alt1_art8-1_par11","fechaAspas":"s","notaAlteracao":"NR","rotulo":"§ 11.","p":[{"TYPE_NAME":"br_gov_lexml__1.GenInline","content":["\n    Regulamento poderá instituir comitê específico de governança, no âmbito do FIIS, para, entre outras competências, estabelecer a regulamentação prevista no art. 4º, § 4º, inciso IV, e realizar os atos atribuídos neste artigo ao Comitê Gestor do FIIS.\n\n  "]}]}}]}}]}}}]}},{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Artigo","prefix":"","key":"{http://www.lexml.gov.br/1.0}Artigo","string":"{http://www.lexml.gov.br/1.0}Artigo"},"value":{"TYPE_NAME":"br_gov_lexml__1.DispositivoType","id":"art4","rotulo":"Art. 4º","lXcontainersOmissis":[{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Caput","prefix":"","key":"{http://www.lexml.gov.br/1.0}Caput","string":"{http://www.lexml.gov.br/1.0}Caput"},"value":{"TYPE_NAME":"br_gov_lexml__1.DispositivoType","id":"art4_cpt","p":[{"TYPE_NAME":"br_gov_lexml__1.GenInline","content":["\n    A ",{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"span","prefix":"","key":"{http://www.lexml.gov.br/1.0}span","string":"{http://www.lexml.gov.br/1.0}span"},"value":{"TYPE_NAME":"br_gov_lexml__1.GenInline","href":"urn:lex:br:federal:medida.provisoria:2026-05-19;1359","content":["Medida Provisória nº 1.359, de 19 de maio de 2026"]}},", passa a vigorar com as seguintes alterações: \n\n  "]}],"alteracao":{"TYPE_NAME":"br_gov_lexml__1.Alteracao","base":"urn:lex:br:federal:medida.provisoria:2026-05-19;1359","id":"art4_cpt_alt1","content":[{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Artigo","prefix":"","key":"{http://www.lexml.gov.br/1.0}Artigo","string":"{http://www.lexml.gov.br/1.0}Artigo"},"value":{"TYPE_NAME":"br_gov_lexml__1.DispositivoType","href":"art6","id":"art4_cpt_alt1_art6","abreAspas":"s","rotulo":"Art. 6º","lXcontainersOmissis":[{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Caput","prefix":"","key":"{http://www.lexml.gov.br/1.0}Caput","string":"{http://www.lexml.gov.br/1.0}Caput"},"value":{"TYPE_NAME":"br_gov_lexml__1.DispositivoType","href":"art6_cpt","id":"art4_cpt_alt1_art6_cpt","textoOmitido":"s","lXcontainersOmissis":[{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Omissis","prefix":"","key":"{http://www.lexml.gov.br/1.0}Omissis","string":"{http://www.lexml.gov.br/1.0}Omissis"},"value":{"TYPE_NAME":"br_gov_lexml__1.Omissis","id":"art4_cpt_alt1_art6_cpt_omi1"}},{"name":{"namespaceURI":"http://www.lexml.gov.br/1.0","localPart":"Inciso","prefix":"","key":"{http://www.lexml.gov.br/1.0}Inciso","string":"{http://www.lexml.gov.br/1.0}Inciso"},"value":{"TYPE_NAME":"br_gov_lexml__1.DispositivoType","href":"art6_cpt_inc2","id":"art4_cpt_alt1_art6_cpt_inc2","fechaAspas":"s","notaAlteracao":"NR","rotulo":"II –","p":[{"TYPE_NAME":"br_gov_lexml__1.GenInline","content":["\n    da informação sobre se o solicitante atende ou não aos critérios de elegibilidade da medida, no caso dos beneficiários de que trata o art. 2º, § 1º, incisos II e III, pela Secretaria Especial da Receita Federal do Brasil do Ministério da Fazenda ou por outros órgãos ou entidades federais detentores de bases de dados.\n\n  "]}]}}]}}]}}]}}}]}},{"name":{"namespaceURI":"http://www.lexml.gov.br/1.